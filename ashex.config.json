{
  "daemon" : {
    "enabled" : false,
    "foregroundPollIntervalSeconds" : 2
  },
  "debug" : {
    "reasoningSummaries" : false
  },
  "dflash" : {
    "baseURL" : "http:\/\/127.0.0.1:8000",
    "enabled" : false,
    "requestTimeoutSeconds" : 120
  },
  "logging" : {
    "level" : "info"
  },
  "network" : {
    "mode" : "allow",
    "rules" : [

    ]
  },
  "ollama" : {
    "contextWindowTokens" : 4096,
    "requestTimeoutSeconds" : 180
  },
  "optimization" : {
    "backend" : "disabled",
    "enabled" : false,
    "esh" : {

    },
    "intent" : "agentrun",
    "mode" : "auto"
  },
  "sandbox" : {
    "mode" : "workspace_write",
    "protectedPaths" : [
      ".git",
      ".ashex",
      ".codex",
      "ashex.config.json"
    ]
  },
  "shell" : {
    "allowList" : [

    ],
    "denyList" : [
      "rm ",
      "sudo ",
      "shutdown",
      "reboot",
      "mkfs",
      "dd ",
      "chown ",
      "launchctl bootout"
    ],
    "requireApprovalForUnknownCommands" : false,
    "rules" : [

    ]
  },
  "telegram" : {
    "accessMode" : "open",
    "allowedChatIDs" : [

    ],
    "allowedUserIDs" : [

    ],
    "enabled" : true,
    "executionPolicy" : "assistant_only",
    "pollingTimeoutSeconds" : 20,
    "responseMode" : "final_message"
  },
  "version" : 1
}
