    "rules" : [

    ]
  },
  "telegram" : {
    "allowedChatIDs" : [

    ],
    "allowedUserIDs" : [

    ],
    "botToken" : null,
    "enabled" : false,
    "executionPolicy" : "assistant_only",
    "pollingTimeoutSeconds" : 20,
    "responseMode" : "final_message"
