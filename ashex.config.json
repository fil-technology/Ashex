    "mode" : "workspace_write",
    "protectedPaths" : [
      ".git",
      ".ashex",
      ".codex",
      "ashex.config.json"
    ]
  },
  "network" : {
    "mode" : "allow",
    "rules" : [

    ]
  },
  "shell" : {
    "allowList" : [

    ],
    "denyList" : [
      "rm ",
      "sudo ",
      "shutdown",
      "reboot",
      "mkfs",
      "dd ",
      "chown ",
      "launchctl bootout"
